{
    "name": "kwidoo/hex-tools",
    "description": "Laravel development tools for Hexagonal and Clean Architecture projects.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/console": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "symfony/process": "^7.0|^8.0",
        "symfony/yaml": "^7.0|^8.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "phpunit/phpunit": "^11.0"
    },
    "suggest": {
        "deptrac/deptrac": "Required to run generated Deptrac architecture checks.",
        "phpmd/phpmd": "Required to run generated PHPMD code smell checks."
    },
    "autoload": {
        "psr-4": {
            "Kwidoo\\HexTools\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kwidoo\\HexTools\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Kwidoo\\HexTools\\HexToolsServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "pest"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
